.country-details-container {
  background-color: var(--elements-color, #fff);
  margin-inline: auto;
  border-radius: 16px;
  max-width: 1200px;
  margin-top: 32px;
  padding: 24px;
  box-shadow: 0 16px 40px #00000014;
}

.back-button {
  cursor: pointer;
  background-color: var(--background-color, #f9fafb);
  color: inherit;
  border: 1px solid #00000014;
  border-radius: 10px;
  align-items: center;
  gap: 10px;
  margin-bottom: 32px;
  padding: 12px 28px;
  transition: transform .2s, box-shadow .2s;
  display: inline-flex;
  box-shadow: 0 8px 20px #00000014;
}

.back-button:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 24px #00000024;
}

.error-message, .country-details-container.loading {
  background: var(--elements-color, #fff);
  text-align: center;
  border-radius: 16px;
  padding: 32px;
  font-size: 1.05rem;
  box-shadow: 0 16px 40px #00000014;
}

.country-details {
  align-items: flex-start;
  gap: 64px;
  margin-top: 24px;
  display: flex;
}

.country-details img {
  object-fit: cover;
  border: 1px solid #00000014;
  border-radius: 16px;
  width: 48%;
  min-width: 320px;
  max-width: 520px;
  box-shadow: 0 16px 32px #00000014;
}

.details-text-container {
  flex-direction: column;
  flex: 1;
  gap: 32px;
  display: flex;
}

.details-text-container h1 {
  letter-spacing: -.03em;
  margin: 0;
  font-size: 2.5rem;
}

.details-text {
  grid-template-columns: repeat(2, minmax(220px, 1fr));
  gap: 24px 48px;
  display: grid;
}

.details-text p {
  color: var(--text-color, #111);
  margin: 0;
  line-height: 1.8;
}

.details-text b {
  margin-bottom: 8px;
  font-weight: 700;
  display: inline-block;
}

.border-countries {
  flex-wrap: wrap;
  align-items: center;
  gap: 12px;
  margin-top: 16px;
  display: flex;
}

.border-countries b {
  min-width: 140px;
  font-weight: 700;
}

.border-countries a {
  background-color: var(--background-color, #f7f7f7);
  color: inherit;
  border-radius: 12px;
  padding: 10px 18px;
  font-size: .95rem;
  text-decoration: none;
  transition: transform .2s, box-shadow .2s;
  box-shadow: 0 10px 24px #00000014;
}

.border-countries a:hover {
  transform: translateY(-1px);
}

@media (width <= 940px) {
  .country-details {
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    margin-top: 24px;
  }

  .details-text {
    grid-template-columns: 1fr;
  }

  .country-details img {
    width: 100%;
    max-width: 100%;
    min-width: unset;
  }
}

@media (width <= 600px) {
  .country-details-container {
    margin-top: 16px;
    padding: 16px;
  }

  .back-button {
    justify-content: center;
    width: 100%;
  }

  .details-text-container h1 {
    font-size: 2rem;
  }

  .details-text {
    gap: 18px;
  }
}

.shimmer-back-button {
  background: linear-gradient(90deg, #0000000f, #00000008, #0000000f);
  border-radius: 10px;
  width: 120px;
  height: 44px;
  margin-bottom: 32px;
  display: inline-block;
  position: relative;
  overflow: hidden;
}

.shimmer-back-button:after {
  content: "";
  background: linear-gradient(90deg, #fff0, #ffffff40, #fff0);
  width: 150px;
  height: 100%;
  animation: 1s linear infinite shimmer;
  position: absolute;
  top: 0;
  left: -150px;
}

.shimmer-detail-image {
  background: linear-gradient(90deg, #0000000f, #00000008, #0000000f);
  border-radius: 16px;
  width: 48%;
  min-width: 320px;
  max-width: 520px;
  height: 360px;
  position: relative;
  overflow: hidden;
}

.shimmer-detail-image:after {
  content: "";
  background: linear-gradient(90deg, #fff0, #ffffff40, #fff0);
  width: 150px;
  height: 100%;
  animation: 1s linear infinite shimmer;
  position: absolute;
  top: 0;
  left: -150px;
}

.shimmer-title {
  background: linear-gradient(90deg, #0000000f, #00000008, #0000000f);
  border-radius: 8px;
  width: 300px;
  height: 48px;
  margin-bottom: 24px;
  position: relative;
  overflow: hidden;
}

.shimmer-title:after {
  content: "";
  background: linear-gradient(90deg, #fff0, #ffffff40, #fff0);
  width: 150px;
  height: 100%;
  animation: 1s linear infinite shimmer;
  position: absolute;
  top: 0;
  left: -150px;
}

.details-text .shimmer-line {
  background: linear-gradient(90deg, #0000000f, #00000008, #0000000f);
  border-radius: 4px;
  height: 18px;
  position: relative;
  overflow: hidden;
}

.details-text .shimmer-line:after {
  content: "";
  background: linear-gradient(90deg, #fff0, #ffffff40, #fff0);
  width: 150px;
  height: 100%;
  animation: 1s linear infinite shimmer;
  position: absolute;
  top: 0;
  left: -150px;
}

.shimmer-border-line {
  background: linear-gradient(90deg, #0000000f, #00000008, #0000000f);
  border-radius: 8px;
  width: 100%;
  height: 40px;
  position: relative;
  overflow: hidden;
}

.shimmer-border-line:after {
  content: "";
  background: linear-gradient(90deg, #fff0, #ffffff40, #fff0);
  width: 150px;
  height: 100%;
  animation: 1s linear infinite shimmer;
  position: absolute;
  top: 0;
  left: -150px;
}

* {
  box-sizing: border-box;
}

body {
  --background-color: white;
  --text-color: black;
  --elements-color: white;
  background-color: var(--background-color);
  color: var(--text-color);
  margin: 0;
  font-family: Nunito, sans-serif;
}

body.dark {
  --background-color: #202c37;
  --text-color: white;
  --elements-color: #2b3945;
}

main {
  padding: 24px;
}

a {
  color: inherit;
  text-decoration-line: none;
}

.header-container {
  background-color: var(--elements-color);
  padding-inline: 24px;
  box-shadow: 0 2px 4px #0000001a;
}

.header-content {
  justify-content: space-between;
  align-items: center;
  max-width: 1200px;
  margin-inline: auto;
  display: flex;
}

.title {
  font-weight: 800;
}

.theme-changer {
  cursor: pointer;
}

.countries-container {
  margin-top: 16px;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  justify-content: space-between;
  gap: 32px;
  max-width: 1200px;
  margin-inline: auto;
  display: grid;
}

.country-card {
  background-color: var(--elements-color);
  border-radius: 8px;
  width: 250px;
  padding-bottom: 24px;
  transition: all .2s ease-in-out;
  display: inline-block;
  overflow: hidden;
  box-shadow: 0 0 8px #0003;
}

.country-card:hover {
  transform: scale(1.03);
  box-shadow: 0 0 16px #0003;
}

.card-title {
  margin-block: 16px;
  font-size: 24px;
}

.card-text {
  padding-inline: 16px;
}

.card-text p {
  margin-block: 8px;
}

.country-card img {
  object-fit: cover;
  width: 100%;
  height: 150px;
  display: block;
}

.search-filter-container {
  margin-inline: auto;
  justify-content: space-between;
  gap: 24px;
  max-width: 1200px;
  margin-top: 16px;
  margin-bottom: 48px;
  display: flex;
}

.search-container {
  color: var(--text-color);
  background-color: var(--elements-color);
  border-radius: 4px;
  width: 100%;
  max-width: 350px;
  padding-left: 24px;
  overflow: hidden;
  box-shadow: 0 0 8px #00000026;
}

.search-container input {
  background-color: inherit;
  width: 90%;
  color: inherit;
  border: none;
  outline: none;
  padding: 16px;
}

.search-container input::placeholder {
  color: #999;
}

.filter-by-region {
  background-color: var(--elements-color);
  width: 250px;
  color: var(--text-color);
  border: none;
  border-radius: 4px;
  outline: none;
  padding: 16px;
  box-shadow: 0 0 8px #00000026;
}

@media (width <= 768px) {
  .countries-container {
    justify-content: center;
  }

  .title {
    font-size: 16px;
  }

  .header-content p {
    font-size: 12px;
  }

  .search-filter-container {
    flex-direction: column;
  }
}

.pagination-controls {
  justify-content: flex-end;
  align-items: center;
  gap: 16px;
  margin-top: 24px;
  display: flex;
}

.pagination-controls button {
  background-color: var(--elements-color);
  color: var(--text-color);
  cursor: pointer;
  border: none;
  border-radius: 8px;
  padding: 10px 18px;
  transition: transform .15s, box-shadow .15s;
  box-shadow: 0 4px 12px #00000014;
}

.pagination-controls button:disabled {
  opacity: .5;
  cursor: not-allowed;
}

.pagination-controls button:hover:not(:disabled) {
  transform: translateY(-1px);
}

.pagination-controls span {
  font-weight: 600;
}

.shimmer-list .country-card {
  pointer-events: none;
  background: var(--elements-color);
}

.shimmer-card {
  position: relative;
  overflow: hidden;
}

.shimmer-card:after {
  content: "";
  background: linear-gradient(90deg, #fff0, #ffffff40, #fff0);
  width: 150px;
  height: 100%;
  animation: 1s linear infinite shimmer;
  position: absolute;
  top: 0;
  left: -150px;
}

.shimmer-flag {
  background: linear-gradient(90deg, #0000000f, #00000008, #0000000f);
  width: 100%;
  height: 150px;
}

.shimmer-line {
  background: linear-gradient(90deg, #0000000f, #00000008, #0000000f);
  border-radius: 4px;
  height: 14px;
  margin: 8px 0;
}

.title-line {
  width: 70%;
  height: 20px;
  margin-top: 12px;
}

.shimmer-line.short {
  width: 60%;
}

@keyframes shimmer {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(300%);
  }
}
